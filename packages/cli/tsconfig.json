{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@mdx-tsx-import-checker/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../core/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
